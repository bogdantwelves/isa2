@page "/movies/edit"
@attribute [ExcludeFromInteractiveRouting]
@using Abc.Soft.Web.Data
@using Microsoft.EntityFrameworkCore
@using Abc.Data
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Movie</h2>
<hr />
@if (movie is null)  // Изменено
{
    <p><em>Loading...</em></p>
}
// ...existing code...
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="@movie" OnValidSubmit="UpdateMovie" FormName="editForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <input type="hidden" name="movie.Id" value="@movie.Id" />

    <MyEditItem Id="title"
                TValue="string"
                Label="Title"
                Value="@movie.Title"
                ValueChanged="@(v => { movie.Title = v; return Task.CompletedTask; })"
                ValueExpression="@(() => movie.Title)" />

    <MyEditItem Id="releaseDate"
                TValue="DateOnly"
                Label="Release Date"
                Value="@movie.ReleaseDate"
                ValueChanged="@(v => { movie.ReleaseDate = v; return Task.CompletedTask; })"
                ValueExpression="@(() => movie.ReleaseDate)" />

    <MyEditItem Id="genre"
                TValue="string"
                Label="Genre"
                Value="@movie.Genre"
                ValueChanged="@(v => { movie.Genre = v; return Task.CompletedTask; })"
                ValueExpression="@(() => movie.Genre)" />

    <MyEditItem Id="price"
                TValue="decimal"
                Label="Price"
                Value="@movie.Price"
                ValueChanged="@(v => { movie.Price = v; return Task.CompletedTask; })"
                ValueExpression="@(() => movie.Price)" />

    <button type="submit" class="btn btn-primary">Save</button>
</EditForm>
        </div>
    </div>
}

<div>
    <a href="/movies">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    [SupplyParameterFromForm]
    private Movie movie { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        movie ??= await context.Movie.FirstOrDefaultAsync(m => m.Id == Id);

        if (movie is null)
        {
            NavigationManager.NotFound();
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateMovie()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(movie!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!MovieExists(movie!.Id))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/movies");
    }

    private bool MovieExists(int id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Movie.Any(e => e.Id == id);
    }

    
}
