@page "/countries/create"
@attribute [ExcludeFromInteractiveRouting]
@using Abc.Data
@using Abc.Infra
@using Abc.Shared.Pages

@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="country" EntityTitle="Country" BasePath="/countries" OnValidSubmit="addCountry" />
@code {
    [SupplyParameterFromForm] private Country country { get; set; } = default!;
    protected override void OnInitialized() => country ??= new();
    private async Task addCountry(){
        await repo.CreateAsync(country);
        NavigationManager.NavigateTo("/countries");
    }
}
